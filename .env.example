# --- Supabase Postgres (Project Settings → Database) ---
# Transaction pooler (PgBouncer), port 6543 — use for Prisma at runtime (Vercel serverless)
# Append: ?pgbouncer=true  (Prisma docs: required for pooler)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (migrations) — "Session" / URI in Supabase, host db.*.supabase.co :5432
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Copy to .env locally. In Vercel: Project → Settings → Environment Variables (add both).

# --- Z AI (z-ai-web-dev-sdk) — optional: use for local dev instead of .z-ai-config
# If Z_AI_BASE_URL and Z_AI_API_KEY are set, they override .z-ai-config. Required for typical Vercel deploys.
# Z_AI_BASE_URL="https://your-api.example.com"
# Z_AI_API_KEY="your-key"
# Z_AI_MODEL="deepseek-ai/deepseek-v4-pro"
# Z_AI_CHAT_ID=""
# Z_AI_USER_ID=""
# Z_AI_TOKEN=""

# NVIDIA (OpenAI-compatible) testing — `src/lib/ai-completions.ts` uses plain fetch + chat_template_kwargs
# Z_AI_BASE_URL="https://integrate.api.nvidia.com/v1"
# Z_AI_API_KEY="nvapi-…"
# Z_AI_MODEL="deepseek-ai/deepseek-v4-pro"
# Z_AI_USE_OPENAI_COMPAT="1"   # optional: force OpenAI-style fetch (auto when URL contains nvidia.com)
# Z_AI_SKIP_CHAT_TEMPLATE_KWARGS="1"  # optional: omit chat_template_kwargs on the request

# See: agent-ctx/ai-api-configuration.md and agent-ctx/ai-api.config.json
